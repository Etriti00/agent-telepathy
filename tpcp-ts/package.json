{
  "name": "tpcp-sdk",
  "version": "0.4.1",
  "description": "Telepathy Communication Protocol - TypeScript/Node.js SDK for multi-agent AI communication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "node": "./dist/index.js",
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    },
    "./browser": "./dist/browser.js"
  },
  "browser": {
    "ws": false
  },
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "build:browser": "tsc --module ESNext --outDir dist/esm",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["ai", "agents", "multi-agent", "protocol", "websocket", "crdt", "ed25519", "llm"],
  "author": "TPCP Contributors",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/Etriti00/agent-telepathy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Etriti00/agent-telepathy.git"
  },
  "bugs": {
    "url": "https://github.com/Etriti00/agent-telepathy/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "fast-json-stable-stringify": "^2.1.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
